# =============================================================================
# CommunityPulse AI Backend - Environment Configuration
# =============================================================================
# 
# SECURITY WARNING: Never commit this file with real credentials!
# Copy this file to .env and update with your actual values
# 
# To generate a secure SECRET_KEY, run:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME="CommunityPulse AI Backend"
APP_VERSION="1.0.0"
APP_ENV="development"  # Options: development, staging, production
DEBUG=true             # Set to false in production!

# JWT Secret Key - MUST be changed in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY="dev-secret-key-change-in-production-min-32-chars-required"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# -----------------------------------------------------------------------------
# Google Cloud Platform Configuration
# -----------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT="communitypulse-ai-demo"
GOOGLE_APPLICATION_CREDENTIALS="credentials/google-cloud-key.json"
GCS_BUCKET_NAME="communitypulse-datasets-bucket"
BIGQUERY_DATASET="community_analytics"
BIGQUERY_LOCATION="US"
FIRESTORE_DATABASE="(default)"
PUBSUB_TOPIC_NOTIFICATIONS="cp-notifications"
PUBSUB_TOPIC_ANALYTICS="cp-analytics"
SECRET_MANAGER_PROJECT="communitypulse-ai-demo"

# -----------------------------------------------------------------------------
# Firebase Authentication Configuration
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""

# -----------------------------------------------------------------------------
# AI Models Configuration (Gemini & Vertex AI)
# -----------------------------------------------------------------------------
# Get your Gemini API key from: https://ai.google.dev/
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash-exp"
GEMINI_MAX_TOKENS=8192
VERTEX_AI_LOCATION="us-central1"
VERTEX_AI_MODEL="gemini-2.0-flash-001"

# -----------------------------------------------------------------------------
# Cache & Message Broker (Redis)
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379/0"
REDIS_CACHE_TTL=3600
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"

# -----------------------------------------------------------------------------
# Security & CORS
# -----------------------------------------------------------------------------
# Add your frontend URLs to CORS_ORIGINS
CORS_ORIGINS='["http://localhost:3000","http://localhost:8080","http://127.0.0.1:8080","http://127.0.0.1:5500"]'
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# -----------------------------------------------------------------------------
# Email & SMS Notifications
# -----------------------------------------------------------------------------
# SMTP Configuration (Gmail example)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""

# Twilio Configuration
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# -----------------------------------------------------------------------------
# GPU Acceleration (Optional)
# -----------------------------------------------------------------------------
GPU_ENABLED=false
GPU_MEMORY_LIMIT_GB=16

# -----------------------------------------------------------------------------
# Logging & Monitoring
# -----------------------------------------------------------------------------
LOG_LEVEL="INFO"  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
ENABLE_CLOUD_LOGGING=false
EXPOSE_METRICS=true
METRICS_PORT=9090
