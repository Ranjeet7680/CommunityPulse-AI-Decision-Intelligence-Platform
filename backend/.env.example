# App Settings
APP_NAME="CommunityPulse AI Backend"
APP_VERSION="1.0.0"
APP_ENV="development"
DEBUG=true
SECRET_KEY="replace-this-with-a-very-secure-random-key-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Google Cloud Project Configuration
GOOGLE_CLOUD_PROJECT="communitypulse-ai-demo"
GOOGLE_APPLICATION_CREDENTIALS="credentials/google-cloud-key.json"
GCS_BUCKET_NAME="communitypulse-datasets-bucket"
BIGQUERY_DATASET="community_analytics"
BIGQUERY_LOCATION="US"
FIRESTORE_DATABASE="(default)"
PUBSUB_TOPIC_NOTIFICATIONS="cp-notifications"
PUBSUB_TOPIC_ANALYTICS="cp-analytics"
SECRET_MANAGER_PROJECT="communitypulse-ai-demo"

# Firebase Config (Base64 string or file path)
FIREBASE_PROJECT_ID="communitypulse-ai-demo"
FIREBASE_PRIVATE_KEY_ID="firebase-private-key-id-placeholder"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQDh...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@communitypulse-ai-demo.iam.gserviceaccount.com"

# Gemini AI & Vertex AI
GEMINI_API_KEY="AIzaSyYourGeminiApiKeyHere"
GEMINI_MODEL="gemini-2.0-flash"
GEMINI_MAX_TOKENS=8192
VERTEX_AI_LOCATION="us-central1"
VERTEX_AI_MODEL="gemini-2.0-flash-001"

# Cache & Message Broker (Redis)
REDIS_URL="redis://localhost:6379/0"
REDIS_CACHE_TTL=3600
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"

# Security & CORS
CORS_ORIGINS='["http://localhost:3000", "http://localhost:8080", "http://127.0.0.1:8080", "http://127.0.0.1:5500"]'
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Notifications (SMTP & Twilio)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="noreply@communitypulse.ai"
SMTP_PASSWORD="your-app-specific-smtp-password"
TWILIO_ACCOUNT_SID="ACtwilioAccountSidPlaceholder"
TWILIO_AUTH_TOKEN="twilioAuthTokenPlaceholder"
TWILIO_PHONE_NUMBER="+1234567890"

# GPU Acceleration Config
GPU_ENABLED=false
GPU_MEMORY_LIMIT_GB=16

# Logging & Monitoring
LOG_LEVEL="INFO"
ENABLE_CLOUD_LOGGING=false
EXPOSE_METRICS=true
METRICS_PORT=9090
